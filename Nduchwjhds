local notifiedEvents = {seaEvent = {}, raidBoss = {}, worldBoss = {}, raceIsland = {}}

local serverStartTime = tick()
local function getServerUptime()
    local uptime = tick() - serverStartTime
    local hours = math.floor(uptime / 3600)
    local minutes = math.floor((uptime % 3600) / 60)
    local seconds = math.floor(uptime % 60)
    return string.format("%02d:%02d:%02d", hours, minutes, seconds)
end

local function getCurrentSea()
    local character = LocalPlayer.Character
    if character and character:FindFirstChild("HumanoidRootPart") then
        local y = character.HumanoidRootPart.Position.Y
        if y < 50 then return "🌊 Sea 1 (First Sea)"
        elseif y < 200 then return "🌊 Sea 2 (Second Sea)"
        elseif y < 500 then return "🌊 Sea 3 (Third Sea)"
        else return "🌊 Vast Sea" end
    end
    return "🌊 Không xác định"
end

local function getBossType(bossName)
    for _, name in pairs(seaEventBosses) do
        if bossName:find(name) or name:find(bossName) then return "seaEvent", name end
    end
    for _, name in pairs(raidBosses) do
        if bossName:find(name) or name:find(bossName) then return "raidBoss", name end
    end
    for _, name in pairs(worldBosses) do
        if bossName:find(name) or name:find(bossName) then return "worldBoss", name end
    end
    return nil, nil
end

local function isRaceIsland(name)
    for _, islandName in pairs(raceIslands) do
        if name:find(islandName) or islandName:find(name) then return true, islandName end
    end
    return false, nil
end

local function notifyIfNewEvent(eventType, eventName)
    local key = eventType .. "_" .. eventName
    if not notifiedEvents[eventType][key] then
        notifiedEvents[eventType][key] = true
        local title = (eventType == "seaEvent" and "🌊 SEA EVENT ĐANG XUẤT HIỆN!") or
                      (eventType == "raidBoss" and "⚔️ RAID BOSS ĐANG XUẤT HIỆN!") or
                      (eventType == "worldBoss" and "🌍 WORLD BOSS ĐANG XUẤT HIỆN!") or
                      (eventType == "raceIsland" and "🏝️ RACE ISLAND ĐANG XUẤT HIỆN!") or
                      "👹 BOSS ĐANG XUẤT HIỆN!"
        Fluent:Notify({Title = title, Content = eventName, SubContent = "Hãy nhanh chóng đến ngay!", Duration = 10})
    end
end

local function resetNotificationIfGone(eventType, eventName)
    local key = eventType .. "_" .. eventName
    if notifiedEvents[eventType][key] then notifiedEvents[eventType][key] = nil end
end

local function scanMapForEvents()
    local events = {seaEvent = {}, raidBoss = {}, worldBoss = {}, raceIsland = {}}
    for _, obj in pairs(workspace:GetDescendants()) do
        if obj:IsA("Model") or obj:IsA("Part") or obj:IsA("MeshPart") then
            local name = obj.Name
            local isRace, raceName = isRaceIsland(name)
            if isRace then table.insert(events.raceIsland, raceName) end
            if obj:FindFirstChild("Humanoid") and obj.Humanoid.Health > 0 then
                local bossType, bossName = getBossType(name)
                if bossType == "seaEvent" then table.insert(events.seaEvent, bossName)
                elseif bossType == "raidBoss" then table.insert(events.raidBoss, bossName)
                elseif bossType == "worldBoss" then table.insert(events.worldBoss, bossName)
                elseif obj.Humanoid.MaxHealth > 5000 then table.insert(events.raidBoss, name) end
            end
            if obj:FindFirstChild("BillboardGui") and obj:FindFirstChild("Humanoid") then
                if obj.Humanoid.Health > 0 and obj.Humanoid.MaxHealth > 5000 then
                    local bossName = obj.Name
                    if not table.find(events.raidBoss, bossName) and not table.find(events.seaEvent, bossName) and not table.find(events.worldBoss, bossName) then
                        table.insert(events.raidBoss, bossName)
                    end
                end
            end
        end
    end
    local function unique(t) local seen, result = {}, {} for _, v in ipairs(t) do if not seen[v] then seen[v] = true table.insert(result, v) end end return result end
    events.seaEvent = unique(events.seaEvent)
    events.raidBoss = unique(events.raidBoss)
    events.worldBoss = unique(events.worldBoss)
    events.raceIsland = unique(events.raceIsland)
    return events
end

local lastScan = {seaEvent = {}, raidBoss = {}, worldBoss = {}, raceIsland = {}}

local function updateStatusAndScan()
    while task.wait(5) do
        playerCountLabel:SetLabel("👥 Người chơi: " .. #Players:GetPlayers())
        local success, ping = pcall(function() return game:GetService("Stats"):GetNetworkStats():GetAveragePing() end)
        if success then pingLabel:SetLabel("📡 Ping: " .. math.floor(ping) .. " ms") end
        serverTimeLabel:SetLabel("⏰ Thời gian: " .. os.date("%H:%M:%S"))
        serverUptimeLabel:SetLabel("⏱️ Uptime: " .. getServerUptime())
        currentSeaLabel:SetLabel(getCurrentSea())
        
        local scanResult = scanMapForEvents()
        
        for _, eventName in pairs(scanResult.seaEvent) do if not table.find(lastScan.seaEvent, eventName) then notifyIfNewEvent("seaEvent", eventName) end end
        for _, eventName in pairs(scanResult.raidBoss) do if not table.find(lastScan.raidBoss, eventName) then notifyIfNewEvent("raidBoss", eventName) end end
        for _, eventName in pairs(scanResult.worldBoss) do if not table.find(lastScan.worldBoss, eventName) then notifyIfNewEvent("worldBoss", eventName) end end
        for _, islandName in pairs(scanResult.raceIsland) do if not table.find(lastScan.raceIsland, islandName) then notifyIfNewEvent("raceIsland", islandName) end end
        
        for _, eventName in pairs(lastScan.seaEvent) do if not table.find(scanResult.seaEvent, eventName) then resetNotificationIfGone("seaEvent", eventName) end end
        for _, eventName in pairs(lastScan.raidBoss) do if not table.find(scanResult.raidBoss, eventName) then resetNotificationIfGone("raidBoss", eventName) end end
        for _, eventName in pairs(lastScan.worldBoss) do if not table.find(scanResult.worldBoss, eventName) then resetNotificationIfGone("worldBoss", eventName) end end
        for _, islandName in pairs(lastScan.raceIsland) do if not table.find(scanResult.raceIsland, islandName) then resetNotificationIfGone("raceIsland", islandName) end end
        
        seaEventLabel:SetLabel(#scanResult.seaEvent > 0 and "🌊 Sea Event: 🟢 " .. table.concat(scanResult.seaEvent, ", ") or "🌊 Sea Event: 🔴 Không có")
        raceIslandLabel:SetLabel(#scanResult.raceIsland > 0 and "🏝️ Race Island: 🟢 " .. table.concat(scanResult.raceIsland, ", ") or "🏝️ Race Island: 🔴 Không có")
        raidBossLabel:SetLabel(#scanResult.raidBoss > 0 and "⚔️ Raid Boss: 🟢 " .. table.concat(scanResult.raidBoss, ", ") or "⚔️ Raid Boss: 🔴 Không có")
        worldBossLabel:SetLabel(#scanResult.worldBoss > 0 and "👹 World Boss: 🟢 " .. table.concat(scanResult.worldBoss, ", ") or "👹 World Boss: 🔴 Không có")
        
        lastScan = scanResult
    end
end

