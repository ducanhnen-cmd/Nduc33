end

local function makeButton(parent, text, color, cb)
    local row = makeRow(parent, 42)
    row.BackgroundColor3 = color or ACCENT
    local label = new("TextLabel", {Parent = row, Text = text, Font = Enum.Font.GothamBold, TextSize = 13, TextColor3 = Color3.fromRGB(20,20,20), BackgroundTransparency = 1, Size = UDim2.new(1,0,1,0), TextXAlignment = Enum.TextXAlignment.Center, TextYAlignment = Enum.TextYAlignment.Center})
    row.MouseButton1Click:Connect(function() if cb then pcall(cb) end end)
    return row
end

local function makeToggle(parent, text, default, cb)
    local row = makeRow(parent, 48)
    local label = new("TextLabel", {Parent = row, Text = text, Font = Enum.Font.Gotham, TextSize = 13, TextColor3 = TXT, BackgroundTransparency = 1, Position = UDim2.new(0,12,0,0), Size = UDim2.new(1,-96,1,0), TextXAlignment = Enum.TextXAlignment.Left, TextYAlignment = Enum.TextYAlignment.Center})
    local sw = new("Frame", {Parent = row, Size = UDim2.new(0,44,0,24), Position = UDim2.new(1,-56,0.5,-12), BackgroundColor3 = default and ACCENT or TOGGLE_OFF})
    new("UICorner", {Parent = sw, CornerRadius = UDim.new(1,0)})
    local knob = new("Frame", {Parent = sw, Size = UDim2.new(0,18,0,18), Position = default and UDim2.new(1,-20,0.5,-9) or UDim2.new(0,4,0.5,-9), BackgroundColor3 = Color3.fromRGB(245,245,245)})
    new("UICorner", {Parent = knob, CornerRadius = UDim.new(1,0)})
    local toggled = default
    local function setState(v)
        toggled = v
        sw.BackgroundColor3 = toggled and ACCENT or TOGGLE_OFF
        knob.Position = toggled and UDim2.new(1,-20,0.5,-9) or UDim2.new(0,4,0.5,-9)
        if cb then pcall(cb, toggled) end
    end
    row.MouseButton1Click:Connect(function() setState(not toggled) end)
    return {Set = setState, Get = function() return toggled end}
end

local function makeSlider(parent, text, minv, maxv, default, cb)
    local row = makeRow(parent, 64)
    local label = new("TextLabel", {Parent = row, Text = text, Font = Enum.Font.Gotham, TextSize = 13, TextColor3 = TXT, BackgroundTransparency = 1, Position = UDim2.new(0,12,0,6), Size = UDim2.new(1,-24,0,18), TextXAlignment = Enum.TextXAlignment.Left})
    local bar = new("Frame", {Parent = row, Size = UDim2.new(1,-120,0,12), Position = UDim2.new(0,12,0,34), BackgroundColor3 = Color3.fromRGB(60,60,60)})
    new("UICorner", {Parent = bar, CornerRadius = UDim.new(0,6)})
    local frac = math.clamp((default-minv)/(maxv-minv),0,1)
    local fill = new("Frame", {Parent = bar, Size = UDim2.new(frac,0,1,0), BackgroundColor3 = ACCENT})
    new("UICorner", {Parent = fill, CornerRadius = UDim.new(0,6)})
    local knob = new("Frame", {Parent = bar, Size = UDim2.new(0,14,0,14), Position = UDim2.new(frac,-7,0.5,-7), BackgroundColor3 = Color3.fromRGB(245,245,245)})
    new("UICorner", {Parent = knob, CornerRadius = UDim.new(1,0)})
    local display = new("TextLabel", {Parent = row, Text = tostring(default), Font = Enum.Font.GothamBold, TextSize = 13, TextColor3 = TXT, BackgroundTransparency = 1, Size = UDim2.new(0,72,0,20), Position = UDim2.new(1,-92,0,22)})
    local dragging = false
    local function update(x)
        local f = math.clamp((x - bar.AbsolutePosition.X) / bar.AbsoluteSize.X, 0, 1)
        local val = math.floor(minv + (maxv - minv) * f + 0.5)
        fill.Size = UDim2.new(f,0,1,0)
        knob.Position = UDim2.new(f,-7,0.5,-7)
        display.Text = tostring(val)
        if cb then pcall(cb, val) end
    end
    knob.InputBegan:Connect(function(i) if i.UserInputType == Enum.UserInputType.MouseButton1 then dragging = true end end)
    knob.InputEnded:Connect(function() dragging = false end)
    bar.InputBegan:Connect(function(i) if i.UserInputType == Enum.UserInputType.MouseButton1 then update(i.Position.X); dragging = true end end)
    UserInputService.InputChanged:Connect(function(i) if dragging and i.UserInputType == Enum.UserInputType.MouseMovement then update(i.Position.X) end end)
    return {Row = row}
end

local function makeDropdown(parent, text, options, default, cb)
    local row = makeRow(parent, 56)
    local label = new("TextLabel", {Parent = row, Text = text, Font = Enum.Font.Gotham, TextSize = 13, TextColor3 = TXT, BackgroundTransparency = 1, Position = UDim2.new(0,12,0,8), Size = UDim2.new(1,-24,0,18), TextXAlignment = Enum.TextXAlignment.Left})
    local btn = new("TextButton", {Parent = row, Size = UDim2.new(1,-24,0,30), Position = UDim2.new(0,12,0,24), BackgroundColor3 = Color3.fromRGB(55,55,55), Text = default or options[1], Font = Enum.Font.Gotham, TextSize = 13, TextColor3 = TXT, AutoButtonColor = false})
    new("UICorner", {Parent = btn, CornerRadius = UDim.new(0,8)})
    local menu = new("ScrollingFrame", {Parent = row, Size = UDim2.new(1,-24,0,120), Position = UDim2.new(0,12,0,54), BackgroundColor3 = Color3.fromRGB(45,45,45), Visible = false, ZIndex = 10, ScrollBarThickness = 4, ClipsDescendants = true})
    new("UICorner", {Parent = menu, CornerRadius = UDim.new(0,8)})
    local menuList = new("UIListLayout", {Parent = menu, Padding = UDim.new(0,2)})
    for _, opt in ipairs(options) do
        local optBtn = new("TextButton", {Parent = menu, Size = UDim2.new(1,-8,0,28), BackgroundColor3 = Color3.fromRGB(55,55,55), BackgroundTransparency = 0.5, Text = opt, Font = Enum.Font.Gotham, TextSize = 13, TextColor3 = TXT, AutoButtonColor = false, ZIndex = 10})
        new("UICorner", {Parent = optBtn, CornerRadius = UDim.new(0,6)})
        optBtn.MouseButton1Click:Connect(function()
            btn.Text = opt
            menu.Visible = false
            if cb then pcall(cb, opt) end
        end)
        optBtn.MouseEnter:Connect(function() optBtn.BackgroundColor3 = ACCENT optBtn.TextColor3 = Color3.fromRGB(20,20,20) end)
        optBtn.MouseLeave:Connect(function() optBtn.BackgroundColor3 = Color3.fromRGB(55,55,55) optBtn.TextColor3 = TXT end)
    end
    menu.Size = UDim2.new(1,-24,0,math.min(#options * 30, 120))
    btn.MouseButton1Click:Connect(function() menu.Visible = not menu.Visible if menu.Visible then menu.ZIndex = 20 end end)
    return {Row = row, Button = btn}
end

