local function makeRow(parent, height)
    local row = new("TextButton", {Parent = parent, Size = UDim2.new(1,0,0,height or 46), BackgroundColor3 = Color3.fromRGB(38,38,38), AutoButtonColor = false, Text = ""})
    new("UICorner", {Parent = row, CornerRadius = UDim.new(0,8)})
