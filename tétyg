-- ========== FAST ATTACK SYSTEM (HOẠT ĐỘNG THẬT - TỐI ƯU) ==========
local fastAttackEnabled = false
local fastAttackConnection = nil
local RS = ReplicatedStorage

local function initFastAttack()
    local success, N = pcall(function() return require(RS.Modules.Net) end)
    if not success then 
        print("[Fast Attack] Không tìm thấy module Net")
        return nil, nil
    end
    
    local hit = N:RemoteEvent("RegisterHit", true)
    local atk = RS.Modules.Net["RE/RegisterAttack"]
    
    return hit, atk
end

local hitRemote, atkRemote = initFastAttack()

local function startFastAttack()
    if fastAttackConnection then return end
    if not hitRemote or not atkRemote then
        hitRemote, atkRemote = initFastAttack()
        if not hitRemote or not atkRemote then return end
    end
    
    local P = LocalPlayer
    
    fastAttackConnection = RunService.Heartbeat:Connect(function()
        if not fastAttackEnabled then return end
        
        local c = P.Character
        if not c then return end
        local r = c:FindFirstChild("HumanoidRootPart")
        if not r then return end
        
        local id = tostring(P.UserId):sub(2,4) .. tostring(coroutine.running()):sub(11,15)
        local didAttack = false
        
        local enemies = Workspace:FindFirstChild("Enemies")
        if enemies then
            for _, m in ipairs(enemies:GetChildren()) do
                local h = m:FindFirstChild("HumanoidRootPart") or m:FindFirstChild("Head")
                local u = m:FindFirstChild("Humanoid")
                if h and u and u.Health > 0 and (h.Position - r.Position).Magnitude <= 60 then
                    if not didAttack then 
                        pcall(function() atkRemote:FireServer() end)
                        didAttack = true 
                    end
                    pcall(function() hitRemote:FireServer(h, {{m, h}}, nil, nil, id) end)
                end
            end
        end
        
        for _, obj in ipairs(Workspace:GetDescendants()) do
            if obj:IsA("Model") and obj:FindFirstChild("Humanoid") and not obj:IsA("Player") then
                local h = obj:FindFirstChild("HumanoidRootPart") or obj:FindFirstChild("Head")
                local u = obj.Humanoid
                if h and u and u.Health > 0 and (h.Position - r.Position).Magnitude <= 60 then
                    if not didAttack then 
                        pcall(function() atkRemote:FireServer() end)
                        didAttack = true 
                    end
                    pcall(function() hitRemote:FireServer(h, {{obj, h}}, nil, nil, id) end)
                end
            end
        end
    end)
    print("[Fast Attack] Đã bật")
end

local function stopFastAttack()
    if fastAttackConnection then
        fastAttackConnection:Disconnect()
        fastAttackConnection = nil
    end
    print("[Fast Attack] Đã tắt")
end

