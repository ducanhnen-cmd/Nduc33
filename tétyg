-- ========== AUTO FARM LEVEL SYSTEM (CÓ FAST ATTACK) ==========
local isFarmingLevel = false
local farmLevelRange = 20
local farmLevelPosition = "Above"
local currentMobTarget = nil

local function findMobByLevel()
    getPlayerLevel()
    local targetZone = nil
    
    for _, zone in ipairs(LevelMapping) do
        if playerLevel >= zone.MinLvl and playerLevel <= zone.MaxLvl then
            targetZone = zone
            break
        end
    end
    
    if not targetZone then
        targetZone = LevelMapping[#LevelMapping]
    end
    
    local hrp = LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart")
    if not hrp then return nil, targetZone end
    
    local closestMob = nil
    local closestDist = farmLevelRange * 2
    
    for _, obj in ipairs(Workspace:GetDescendants()) do
        if obj:IsA("Model") and obj:FindFirstChild("Humanoid") then
            local humanoid = obj.Humanoid
            if humanoid.Health > 0 then
                local name = obj.Name:lower()
                local isTarget = false
                
                for _, mobName in ipairs(targetZone.Mobs) do
                    if name:find(mobName:lower()) then
                        isTarget = true
                        break
                    end
                end
                
                if isTarget then
                    local mobHrp = obj:FindFirstChild("HumanoidRootPart") or obj:FindFirstChild("Head")
                    if mobHrp then
                        local dist = (hrp.Position - mobHrp.Position).Magnitude
                        if dist < closestDist then
                            closestDist = dist
                            closestMob = {
                                Object = obj,
                                Position = mobHrp.Position,
                                Humanoid = humanoid,
                                CFrame = mobHrp.CFrame
                            }
                        end
                    end
                end
            end
        end
    end
    return closestMob, targetZone
end

local function getFarmDesiredPosition(targetPos, targetCFrame)
    if farmLevelPosition == "Behind" and targetCFrame then
        return targetPos + targetCFrame.LookVector * -farmLevelRange
    elseif farmLevelPosition == "Under" then
        return Vector3.new(targetPos.X, targetPos.Y - farmLevelRange, targetPos.Z)
    else
        local hrp = LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart")
        if hrp then
            local dir = (targetPos - hrp.Position).Unit
            return targetPos - dir * farmLevelRange
        end
        return targetPos + Vector3.new(farmLevelRange, 0, farmLevelRange)
    end
end

local function moveToMob(target)
    local hrp = LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart")
    if not hrp then return false end
    
    local desired = getFarmDesiredPosition(target.Position, target.CFrame)
    
    if (hrp.Position - desired).Magnitude > 10 then
        hrp.CFrame = CFrame.new(desired)
        return false
    end
    return true
end

local function handleQuest(targetZone)
    if not targetZone then return end
    
    local hrp = LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart")
    if hrp and (hrp.Position - targetZone.QuestLocation).Magnitude > 200 then
        hrp.CFrame = CFrame.new(targetZone.QuestLocation)
        wait(0.5)
    end
    
    local questNPC = nil
    for _, obj in ipairs(Workspace:GetDescendants()) do
        if obj:IsA("Model") and (obj.Name:find("Quest") or obj.Name:find(targetZone.QuestNPC)) then
            questNPC = obj
            break
        end
    end
    
    if questNPC then
        local remotes = {
            ReplicatedStorage:FindFirstChild("RequestQuest"),
            ReplicatedStorage:FindFirstChild("TalkNPC"),
            ReplicatedStorage:FindFirstChild("Quest")
        }
        for _, remote in ipairs(remotes) do
            if remote then
                pcall(function() remote:FireServer(questNPC) end)
                wait(0.3)
                break
            end
        end
    end
end

local function startFarmLevel()
    if isFarmingLevel then return end
    isFarmingLevel = true
    
    -- TỰ ĐỘNG BẬT FAST ATTACK
    if not fastAttackEnabled then
        fastAttackEnabled = true
        startFastAttack()
        print("[Fast Attack] Tự động bật cùng Farm Level")
    end
    
    print("[Farm Level] Started with Fast Attack")
    
    task.spawn(function()
        while isFarmingLevel do
            if not LocalPlayer.Character or not LocalPlayer.Character:FindFirstChild("HumanoidRootPart") then
                wait(2)
                goto continue
            end
            
            local mob, targetZone = findMobByLevel()
            
            if not mob then
                if targetZone then
                    local hrp = LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart")
                    if hrp and (hrp.Position - targetZone.QuestLocation).Magnitude > 300 then
                        print("[Farm] Moving to:", targetZone.Island)
                        hrp.CFrame = CFrame.new(targetZone.QuestLocation)
                        wait(1)
                    else
                        handleQuest(targetZone)
                    end
                end
                wait(3)
                goto continue
            end
            
            currentMobTarget = mob
            if moveToMob(mob) then
                wait(0.1)
            else
                wait(0.2)
            end
            
            ::continue::
        end
    end)
end

local function stopFarmLevel()
    isFarmingLevel = false
    currentMobTarget = nil
    
    if not isFarmingCakePrince and not isFarmingDoughKing then
        if fastAttackEnabled then
            fastAttackEnabled = false
            stopFastAttack()
            print("[Fast Attack] Tự động tắt")
        end
    end
    
    print("[Farm Level] Stopped")
end

